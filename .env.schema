AUTH_GITHUB_ID=OAuth app id
AUTH_GITHUB_SECRET=OAuth app secret
AUTH_SECRET=Some key used to sign auth cookies
WHITELIST=Emails of GitHub accounts that you want to permit access
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# For running prod locally
# AUTH_GITHUB_ID=localhost OAuth app id
# AUTH_GITHUB_SECRET=localhost OAuth app secret

# When using ngrok
# AUTH_URL=https://<ngrok-url>/api/auth
# ALLOWED_DEV_ORIGINS=<ngrok-url>

# When deploying to an unknown host
# AUTH_URL=https://<deployment-url>/api/auth
