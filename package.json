{
  "name": "next-simple-chatgpt",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "analyze": "cross-env ANALYZE=true next build",
    "beforebuild": "pnpm generate:refractor-languages && node ./scripts/generateBuildTimestamp.ts",
    "build": "pnpm beforebuild && next build",
    "build:e2e": "pnpm beforebuild && cross-env NEXT_PUBLIC_E2E=true next build",
    "create-certificate": "node ./scripts/createCertificate.ts",
    "predev": "pnpm generate:refractor-languages",
    "dev": "del-cli .next && concurrently \"next dev --port 3030 --experimental-https\" \"pnpm panda:watch\"",
    "dev:e2e": "del-cli .next && concurrently \"node ./scripts/runNext.ts --e2e\" \"pnpm panda:watch\"",
    "generate:refractor-languages": "node ./scripts/generateRefractorLanguageImports.ts",
    "lint": "oxlint --report-unused-disable-directives-severity=error",
    "panda:watch": "panda --watch",
    "prepare": "concurrently \"husky\" \"panda codegen\"",
    "start": "next start",
    "start:local": "concurrently \"next start -p 3031\" \"npx local-ssl-proxy --key ./certificates/localhost-key.pem --cert ./certificates/localhost.pem --source 3030 --target 3031\"",
    "test": "vitest",
    "e2e": "cross-env NODE_ENV=production NEXT_PUBLIC_E2E=true  playwright test",
    "e2e:debug": "playwright test --debug",
    "e2e:ui": "playwright test --ui",
    "typecheck": "tsgo",
    "playground": "ts ./playground.ts"
  },
  "dependencies": {
