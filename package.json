{
  "name": "next-simple-chatgpt",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "analyze": "cross-env ANALYZE=true next build",
    "beforebuild": "pnpm generate:refractor-languages && node ./scripts/generateBuildTimestamp.ts",
    "build": "pnpm beforebuild && next build && pnpm afterbuild",
    "build:e2e": "pnpm beforebuild && cross-env NEXT_PUBLIC_E2E=true next build && pnpm afterbuild",
    "afterbuild": "shx cp -r public .next/standalone/public && shx cp -r .next/static .next/standalone/.next/static",
    "predev": "pnpm generate:refractor-languages",
    "dev": "del-cli .next && concurrently \"next dev\" \"pnpm panda:watch\"",
    "dev:e2e": "del-cli .next && concurrently \"cross-env NEXT_PUBLIC_E2E=true next dev\" \"pnpm panda:watch\"",
    "generate:refractor-languages": "node ./scripts/generateRefractorLanguageImports.ts",
    "lint": "oxlint --report-unused-disable-directives-severity=error",
    "panda:watch": "panda --watch",
    "prepare": "concurrently \"husky\" \"panda codegen\" \"pnpm generate:refractor-languages\"",
    "start": "dotenv -e .env.local -- node .next/standalone/server.js",
    "test": "vitest",
    "e2e": "cross-env NODE_ENV=production NEXT_PUBLIC_E2E=true  playwright test",
    "e2e:debug": "playwright test --debug",
    "e2e:ui": "playwright test --ui",
    "typecheck": "tsgo",
    "playground": "ts ./playground.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^2.0.70",
    "@ai-sdk/openai": "^2.0.98",
    "@ai-sdk/react": "^2.0.152",
    "@openrouter/ai-sdk-provider": "^1.5.4",
    "@pandacss/dev": "^0.53.7",
    "@tanstack/react-query": "^5.90.21",
    "ai": "^5.0.150",
    "concurrently": "^8.2.2",
    "date-fns": "^3.6.0",
    "hast-util-to-jsx-runtime": "^2.3.6",
    "lodash": "^4.17.23",
    "next": "^16.1.6",
    "next-auth": "5.0.0-beta.30",
    "pdfjs-dist": "5.2.133",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "react-markdown": "^10.1.0",
    "refractor": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "superjson": "^2.2.6",
    "use-local-storage-state": "^19.5.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.1.6",
    "@next/eslint-plugin-next": "^16.1.6",
    "@playwright/test": "^1.58.2",
    "@types/lodash": "^4.17.24",
    "@types/node": "^22.19.15",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@typescript/native-preview": "7.0.0-dev.20260307.1",
    "cross-env": "^7.0.3",
    "del-cli": "^6.0.0",
    "dotenv": "^17.3.1",
    "dotenv-cli": "^11.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "oxlint-tsgolint": "^0.16.0",
    "prettier": "^3.8.1",
    "shx": "^0.4.0",
    "typescript": "5.9.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.31.0+sha512.e3927388bfaa8078ceb79b748ffc1e8274e84d75163e67bc22e06c0d3aed43dd153151cbf11d7f8301ff4acb98c68bdc5cadf6989532801ffafe3b3e4a63c268"
}
