{
  "name": "next-simple-chatgpt",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "analyze": "next experimental-analyze",
    "beforebuild": "pnpm generate:refractor-languages && node ./scripts/generateBuildTimestamp.ts",
    "build": "pnpm beforebuild && next build && pnpm afterbuild",
    "build:e2e": "pnpm beforebuild && cross-env NEXT_PUBLIC_TEST=true next build && pnpm afterbuild",
    "afterbuild": "shx cp -r public .next/standalone/public && shx cp -r .next/static .next/standalone/.next/static",
    "predev": "pnpm generate:refractor-languages",
    "dev": "del-cli .next && concurrently \"next dev\" \"pnpm panda:watch\"",
    "dev:e2e": "del-cli .next && concurrently \"cross-env NEXT_PUBLIC_TEST=true next dev\" \"pnpm panda:watch\"",
    "generate:refractor-languages": "node ./scripts/generateRefractorLanguageImports.ts",
    "format": "oxfmt",
    "lint": "oxlint",
    "panda:watch": "panda --watch",
    "prepare": "concurrently \"husky\" \"panda codegen\" \"pnpm generate:refractor-languages\" \"shx mkdir -p public && shx cp node_modules/pdfjs-dist/build/pdf.worker.min.mjs public/pdf.worker.min.mjs\"",
    "start": "dotenv -e .env.local -- node .next/standalone/server.js",
    "test": "cross-env NEXT_PUBLIC_TEST=true vitest",
    "e2e": "cross-env NODE_ENV=production NEXT_PUBLIC_TEST=true playwright test",
    "e2e:debug": "cross-env NEXT_PUBLIC_TEST=true playwright test --debug",
    "e2e:dev": "cross-env NEXT_PUBLIC_TEST=true playwright test",
    "e2e:install": "playwright install --with-deps chromium",
    "e2e:ui": "cross-env NEXT_PUBLIC_TEST=true playwright test --ui",
    "typecheck": "tsgo"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.12",
    "@ai-sdk/openai": "^4.0.11",
    "@ai-sdk/react": "^4.0.23",
    "@openrouter/ai-sdk-provider": "^3.0.0",
    "@pandacss/dev": "^1.11.4",
    "@tanstack/react-query": "^5.101.2",
    "ai": "^7.0.22",
    "concurrently": "^10.0.3",
    "date-fns": "^4.4.0",
    "hast-util-to-jsx-runtime": "^2.3.6",
    "jotai": "^2.20.1",
    "lodash-es": "^4.18.1",
    "next": "^16.2.10",
    "pdfjs-dist": "6.1.200",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.7.0",
    "react-markdown": "^10.1.0",
    "react-window": "^2.2.7",
    "refractor": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "superjson": "^2.2.6",
    "use-local-storage-state": "^20.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@s-h-a-d-o-w/oxlint-config": "^1.0.4",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^26",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260707.2",
    "cross-env": "^10.1.0",
    "del-cli": "^7.0.0",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "oxlint-tsgolint": "^0.24.0",
    "shx": "^0.4.0",
    "typescript": "7.0.2",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.15.0+sha512.266f8957a30d2be6e9468e5e66bcdedd35a794175f71b067ba8504d686cce1d0c0f429b33c323c3c569ad4891e667574a49ff71d1b89a22cc66f13c65818c578"
}
